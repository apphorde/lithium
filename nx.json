{
  "workspaceLayout": {
    "libsDir": "./lib",
    "appsDir": "./lib"
  },
  "targetDefaults": {
    "tsc": {
      "dependsOn": ["^tsc", "^build"],
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc -p {projectRoot}/tsconfig.json --noEmit --rootDir {projectRoot}"
      }
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "executor": "nx:run-commands",
      "options": {
        "command": "rollup -c {projectRoot}/rollup.config.js"
      }
    },
    "unit": {
      "cache": true
    },
    "nodeTest": {
      "dependsOn": ["build", "tsc"],
      "executor": "nx:run-commands",
      "options": {
        "command": "test -f {projectRoot}/src/index.spec.ts && npx tsx {projectRoot}/src/index.spec.ts"
      }
    }
  },
  "plugins": [
    {
      "plugin": "@nx/vitest",
      "options": {
        "testTargetName": "unit"
      }
    }
  ],
  "analytics": false
}
